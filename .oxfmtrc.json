{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 80,
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "/dist",
    "/coverage",
    "/.nx/cache",
    "/.nx/workspace-data",
    "**/routeTree.gen.ts",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock"
  ]
}

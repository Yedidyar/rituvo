# Local development only — do not copy this line into a real deployment.
# Makes CLERK_WEBHOOK_SIGNING_SECRET optional below (webhooks can't reach
# localhost, so there's nothing to configure yet). Any other value, including
# unset, keeps it required — so a deploy that forgets NODE_ENV still fails to
# boot rather than silently skipping webhook verification.
NODE_ENV=development

# Host the server binds to (required). Use 0.0.0.0 to accept connections from
# other devices on the LAN (e.g. testing the web app on a phone); localhost
# binds to the loopback interface only.
HOST=localhost
# Port the server listens on (required; use 3001 in dev so the
# web app can keep 3000)
PORT=3001

# Database URL for PostgreSQL (required; the server will not boot without it)
DATABASE_URL="postgresql://username:password@localhost:5432/mydb"

# Clerk keys (required; the server will not boot without them)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Svix signing secret of the Clerk webhook endpoint (starts with whsec_);
# required for POST /webhooks/clerk to accept events. Optional only when
# NODE_ENV=development (see note above); required otherwise.
CLERK_WEBHOOK_SIGNING_SECRET=

# Origin of the web app allowed to call this API from the browser (CORS).
# For LAN/device testing, set this to the device-facing web origin,
# e.g. http://192.168.1.20:3000
WEB_ORIGIN=http://localhost:3000

# Clerk
# Clerk publishable key (required; must start with pk_)
VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the Fastify API (used to sync the signed-in user).
# For device/mobile testing over the LAN, point this at the dev machine's IP
# instead of localhost, e.g. http://192.168.1.20:3001
VITE_API_URL=http://localhost:3001

# Database URL for PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/mydb"

# Expose the dev server on the LAN (0.0.0.0) for device/mobile testing;
# binds to localhost when unset. Pair with VITE_API_URL above and, on the
# API, HOST=0.0.0.0 + a matching WEB_ORIGIN.
EXPOSE_DEV_SERVER=

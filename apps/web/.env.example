# Clerk
# Set to false to disable Clerk auth (e.g. during local dev without keys)
VITE_CLERK_ENABLED=false
# Clerk publishable key (required when enabled; must start with pk_)
VITE_CLERK_PUBLISHABLE_KEY=

# Base URL of the Fastify API (used to sync the signed-in user)
VITE_API_URL=http://localhost:3001

# Database URL for PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/mydb"
